{
  "name": "woonuxt",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "graphql:codegen:check": "npm run graphql:codegen && git diff --exit-code -- woonuxt_base/app/gql/default.ts",
    "dev": "nuxt dev --host 0.0.0.0",
    "dev:ssl": "NODE_TLS_REJECT_UNAUTHORIZED=0 nuxt dev --host 0.0.0.0 --https --ssl-cert localhost.pem --ssl-key localhost-key.pem",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "serve": "nuxi generate && npx serve .output/public -l 8080",
    "typecheck": "nuxi typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.12.0",
    "@tailwindcss/vite": "^4.3.3",
    "@vueuse/core": "^14.3.0",
    "graphql": "^16.14.2",
    "graphql-request": "^7.4.0",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^7.1.0",
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-graphql-request": "^7.1.0",
    "@graphql-codegen/typescript-operations": "5.1.0",
    "@iconify-json/ion": "^1.2.7",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/icon": "^2.3.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/i18n": "^10.4.1",
    "@tailwindcss/typography": "^0.5.20",
    "@vite-pwa/nuxt": "^1.1.1",
    "eslint": "^10.7.0",
    "nuxt": "^4.5.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.7"
  }
}
